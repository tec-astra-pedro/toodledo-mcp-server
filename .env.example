# Toodledo app credentials — register an app at
# https://api.toodledo.com/3/account/index.php to obtain these.
TOODLEDO_CLIENT_ID=your_client_id
TOODLEDO_CLIENT_SECRET=your_client_secret

# Optional overrides (defaults shown):
# TOODLEDO_REDIRECT_URI=http://127.0.0.1:8585/callback
# TOODLEDO_SCOPE=basic tasks notes outlines lists write
# TOODLEDO_TOKEN_PATH=/path/to/.toodledo-token.json

# Optional: bypass the token file entirely with an explicit refresh token.
# Rarely needed — `npm run auth` manages the token file for you.
# TOODLEDO_REFRESH_TOKEN=
